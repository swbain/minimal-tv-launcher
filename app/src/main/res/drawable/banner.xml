    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <path
        android:fillColor="#12141A"
        android:pathData="M0,0 h320 v180 h-320 z" />

    <!-- Row of app tiles -->
    <path android:fillColor="#3D5AFE" android:pathData="M96,64 h36 a6,6 0 0 1 6,6 v40 a6,6 0 0 1 -6,6 h-36 a6,6 0 0 1 -6,-6 v-40 a6,6 0 0 1 6,-6 z" />
    <path android:fillColor="#00B0FF" android:pathData="M142,64 h36 a6,6 0 0 1 6,6 v40 a6,6 0 0 1 -6,6 h-36 a6,6 0 0 1 -6,-6 v-40 a6,6 0 0 1 6,-6 z" />
    <path android:fillColor="#1DE9B6" android:pathData="M188,64 h36 a6,6 0 0 1 6,6 v40 a6,6 0 0 1 -6,6 h-36 a6,6 0 0 1 -6,-6 v-40 a6,6 0 0 1 6,-6 z" />
</vector>
